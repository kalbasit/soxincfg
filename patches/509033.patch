From 694c89ec5e92349f6fd3d74e1a41126cdcdea60d Mon Sep 17 00:00:00 2001
From: Wael Nasreddine <wael.nasreddine@gmail.com>
Date: Sat, 11 Apr 2026 10:25:27 -0700
Subject: [PATCH 1/3] openspec: add kalbasit as maintainer

---
 pkgs/by-name/op/openspec/package.nix | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/pkgs/by-name/op/openspec/package.nix b/pkgs/by-name/op/openspec/package.nix
index e72807f2b4c7a..b6a01ffbf89c4 100644
--- a/pkgs/by-name/op/openspec/package.nix
+++ b/pkgs/by-name/op/openspec/package.nix
@@ -74,7 +74,10 @@ stdenvNoCC.mkDerivation (finalAttrs: {
     description = "AI-native system for spec-driven development";
     homepage = "https://github.com/Fission-AI/OpenSpec";
     license = lib.licenses.mit;
-    maintainers = with lib.maintainers; [ superherointj ];
+    maintainers = with lib.maintainers; [
+      kalbasit
+      superherointj
+    ];
     platforms = lib.platforms.all;
     mainProgram = "openspec";
   };

